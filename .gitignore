# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# MCP config files (contain sensitive tokens — do not commit)
n8n-mcp-config.json
supabase-mcp-config.json

# Backup env files
*.bak

# Private owner documentation
docs/PROPIETARIO_GUIA_PRIVADA.md
