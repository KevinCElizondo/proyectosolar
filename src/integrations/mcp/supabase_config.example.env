# URL de su proyecto Supabase
SUPABASE_URL=https://su-proyecto-id.supabase.co

# Clave API anónima (pública) de Supabase
# Importante: Esta es la clave pública, no la clave secreta
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS...
