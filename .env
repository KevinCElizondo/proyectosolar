# API Configuration
VITE_API_URL=http://localhost:3000

# Authentication
VITE_AUTH_SECRET=dev-secret-key-change-in-production

# Payment Gateway (PayPal Sandbox)
VITE_PAYPAL_CLIENT_ID=sandbox-client-id
