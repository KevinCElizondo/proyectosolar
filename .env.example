# API Configuration
VITE_API_URL=http://localhost:3000

# Authentication
VITE_AUTH_SECRET=your-auth-secret

# Payment Gateway (PayPal)
VITE_PAYPAL_SANDBOX_CLIENT_ID=your-paypal-sandbox-client-id
VITE_PAYPAL_SANDBOX_SECRET=your-paypal-sandbox-secret
VITE_PAYPAL_LIVE_CLIENT_ID=your-paypal-live-client-id

# Convex
VITE_CONVEX_DEPLOY_KEY=your-convex-deploy-key
VITE_PAYPAL_LIVE_SECRET=your-paypal-live-secret

# External Services (e.g., N8N for automation)
VITE_N8N_WEBHOOK_URL=your-n8n-webhook-url

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
