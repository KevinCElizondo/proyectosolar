# ============================================================
#  SolarFluidity — Variables de Entorno
#  Copia este archivo a .env.local y completa los valores.
#  NUNCA comitees .env.local al repositorio.
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PAYPAL (Suscripciones recurrentes) ───────────────────────
# Usar IDs de Sandbox en desarrollo, Live en producción
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=EXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_PLAN_STANDARD=P-XXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_PAYPAL_PLAN_EARLYBIRD=P-YYYYYYYYYYYYYYYYYYYYYYYY

# ── EMAIL / RESEND ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=kevincordero@solarfluidity.com

# ── MAKE.COM (Orquestador central de automatizaciones) ────────
# Escenario 1: Captura de lead desde landing page
MAKE_WEBHOOK_LEAD_CAPTURE=https://hook.eu2.make.com/xxxxxxxxxxxxxxxx
# Escenario 3: Procesamiento de compra (Stripe → entrega + upsell)
MAKE_WEBHOOK_PURCHASE=https://hook.eu2.make.com/yyyyyyyyyyyyyyyy

# ── MAILERLITE (Email marketing — secuencia de ventas 7 días) ─
MAILERLITE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
MAILERLITE_GROUP_LEADS=123456789
MAILERLITE_GROUP_CLIENTS=987654321

# ── STRIPE (Cobros directos — productos digitales) ────────────
# Solo necesario para la capa de venta de productos digitales
# STRIPE_SECRET_KEY=<tu-stripe-secret-key>
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<tu-stripe-publishable-key>
# STRIPE_WEBHOOK_SECRET=<tu-stripe-webhook-secret>
