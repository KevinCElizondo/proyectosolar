# PayPal Credentials (Sandbox for development, Live for production)
NODE_ENV=development

# Use Sandbox credentials by default
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_SECRET=your-paypal-sandbox-secret

# Add Live credentials if needed for production builds
# PAYPAL_LIVE_CLIENT_ID=your-paypal-live-client-id
# PAYPAL_LIVE_SECRET=your-paypal-live-secret

# Server Configuration
PORT=4000 # Port for the backend API server
FRONTEND_URL=http://localhost:5173 # URL of the React frontend (for CORS) - Adjust if different